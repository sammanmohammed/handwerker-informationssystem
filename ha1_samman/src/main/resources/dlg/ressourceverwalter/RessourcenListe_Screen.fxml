<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<VBox xmlns="http://javafx.com/javafx/23.0.1"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="de.opp3.samman.dlg.ressourceverwalter.RessourcenListeScreenController"
    prefHeight="400.0" prefWidth="600.0"
    alignment="TOP_CENTER" spacing="20.0">

    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
    </padding>

    <children>

        <Label text="Ressourcen Liste" textAlignment="CENTER">
            <font>
                <Font size="24.0" />
            </font>
        </Label>


        <TableView fx:id="tv_ressourcen" prefHeight="500.0" prefWidth="700.0">
            <columns>
                <TableColumn fx:id="tc_id" prefWidth="100.0" text="ID" />
                <TableColumn fx:id="tc_art" prefWidth="100.0" text="Art" />
                <TableColumn fx:id="tc_standrdKostensatz" prefWidth="100.0" text="StandrdKostensatz" />
                <TableColumn fx:id="tc_name" prefWidth="100.0" text="Name" />
            
            </columns>
        </TableView>


        <HBox alignment="CENTER" spacing="10.0">
            <children>
            

                <Button mnemonicParsing="false" text="Zurück"
                    onAction="#bt_zurueckClicked" />

                        <Button mnemonicParsing="false" text="Filtere nach Pries aufsteigend"
                    onAction="#bt_filternachpriesaufteigend" />

                        <Button mnemonicParsing="false" text="Filter Deativieren"
                    onAction="#bt_filterdeaktivieren" />

                    <Button mnemonicParsing="false" text="Filter absteigend"
                    onAction="#bt_filternachpriesabsteigend" />

            </children>
        </HBox>
    </children>
</VBox>