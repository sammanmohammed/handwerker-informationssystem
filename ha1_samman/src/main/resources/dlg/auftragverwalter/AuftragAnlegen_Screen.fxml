<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/23.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="de.opp3.samman.dlg.auftragverwalter.AuftragAnlegenScreenController"
      alignment="TOP_CENTER" spacing="20"
      prefWidth="600" prefHeight="400">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <children>

        <Label text="Kundenauftrag anlegen">
            <font><Font size="24"/></font>
        </Label>

        <TableView fx:id="tv_kunden" prefHeight="200.0" prefWidth="400.0">
            <columns>
                <TableColumn fx:id="tc_kundenNr" prefWidth="150.0" text="Kundennummer" />
                <TableColumn fx:id="tc_vorname" prefWidth="200.0" text="Vorname" />
                <TableColumn fx:id="tc_nachname" prefWidth="310.0" text="Nachname" />
            </columns>
        </TableView>

        <Label text="Beschreibung (max. 2000 Zeichen)"/>
        <TextArea fx:id="ta_beschreibung"
                  prefWidth="560" prefHeight="150"
                  promptText="Beschreibung des Auftrags eingeben..."/>

        <HBox alignment="CENTER" spacing="15">
            <children>
                <Button text="Zurück" onAction="#bt_zurueckClicked"/>
                <Button text="Speichern" onAction="#bt_speichernClicked"/>
            </children>
        </HBox>
    </children>
</VBox>
